{
  "MaxConcurrent": {
    "Computers": 10,
    "FoldersPerMatrix": 3,
    "JobsPerRemoteComputer": 3
  },
  "Matrix": {
    "FolderPath": "C:\\Permission matrix files",
    "DefaultsFile": "C:\\Permission matrix files\\Defaults.xlsx",
    "Archive": false,
    "AdGroupPlaceHolders": [
      "cnorris"
    ]
  },
  "Export": {
    "ServiceNowFormDataExcelFile": null,
    "OverviewHtmlFile": null,
    "PermissionsExcelFile": null
  },
  "ServiceNow": {
    "CredentialsFilePath": null,
    "Environment": null,
    "TableName": null
  },
  "PSSessionConfiguration": "PowerShell.7",
  "AuditReport": {
    "RequestTicketURL": "https://heidelbergmaterialsprod.service-now.com/esc?id=sc_cat_item&sys_id=edeeb8cd3bbfa2903146604a85e45af2",
    "ScriptAdmin": [
      "it-access-admin@example.com"
    ]
  },
  "Settings": {
    "ScriptName": "Permission matrix audit report",
    "SendMail": {
      "From": "no-reply-bnl-audit@example.com",
      "FromDisplayName": "Permission matrix audit report",
      "To": [],
      "Bcc": [
        "it-access-admin@example.com"
      ],
      "Subject": "Access review - {{MatrixFileName}} ({{UniqueUserCount}} users, {{UniqueGroupCount}} groups)",
      "Body": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#f4f6f8;margin:0;padding:24px 0;font-family:Arial,Helvetica,sans-serif;\"><tr><td align=\"center\" style=\"padding:0 12px;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:100%;max-width:600px;margin:0 auto;background-color:#ffffff;border:1px solid #e1e6ea;\"><tr><td bgcolor=\"#1f3a5f\" style=\"background-color:#1f3a5f;padding:22px 28px;\"><div style=\"color:#ffffff;font-size:20px;font-weight:bold;letter-spacing:0.2px;\">Access role review</div><div style=\"color:#aebfd4;font-size:13px;padding-top:4px;\">Permission matrix audit &middot; please review your folder access</div></td></tr><tr><td style=\"padding:24px 28px 6px 28px;color:#333333;font-size:14px;line-height:22px;\"><p style=\"margin:0 0 14px 0;\">Dear matrix responsible,</p><p style=\"margin:0 0 14px 0;\">You received this message because you were designated as manager of an access role matrix.</p><p style=\"margin:0 0 14px 0;\">Managing folder access is not always easy &mdash; people join and leave, move departments, and change jobs. To help, the &lsquo;Permission matrix&rsquo; script automatically sets permissions on the files and folders shared with your colleagues.</p><p style=\"margin:0 0 4px 0;\">From time to time a short review is useful. Please check the details below and the file in attachment to confirm they are still valid.</p></td></tr><tr><td style=\"padding:14px 28px 4px 28px;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td bgcolor=\"#2e7d9a\" style=\"background-color:#2e7d9a;border-radius:4px;\"><a href=\"{{RequestTicketURL}}\" target=\"_blank\" style=\"display:inline-block;padding:12px 24px;color:#ffffff;font-size:14px;font-weight:bold;text-decoration:none;\">Request a change &rarr;</a></td></tr></table><p style=\"margin:10px 0 0 0;color:#6b7280;font-size:12px;line-height:18px;\">Submit the &ldquo;BNL Folder Roles Access Request&rdquo; form on the IT Self-service Portal.</p></td></tr><tr><td style=\"padding:16px 28px 4px 28px;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:100%;border-collapse:collapse;font-size:13px;\"><tr><td colspan=\"2\" bgcolor=\"#eef3f7\" style=\"background-color:#eef3f7;padding:11px 14px;border:1px solid #d6dee6;word-break:break-word;overflow-wrap:break-word;\"><a href=\"{{MatrixFilePath}}\" style=\"color:#1f3a5f;font-weight:bold;font-size:14px;text-decoration:none;\">{{MatrixFileName}}.xlsx</a></td></tr><tr><td width=\"38%\" style=\"width:38%;background-color:#fafbfc;color:#6b7280;padding:10px 14px;border:1px solid #d6dee6;\">Category</td><td style=\"padding:10px 14px;border:1px solid #d6dee6;color:#333333;word-break:break-word;overflow-wrap:break-word;\">{{MatrixCategoryName}}</td></tr><tr><td style=\"background-color:#fafbfc;color:#6b7280;padding:10px 14px;border:1px solid #d6dee6;\">Sub category</td><td style=\"padding:10px 14px;border:1px solid #d6dee6;color:#333333;word-break:break-word;overflow-wrap:break-word;\">{{MatrixSubCategoryName}}</td></tr><tr><td style=\"background-color:#fafbfc;color:#6b7280;padding:10px 14px;border:1px solid #d6dee6;\">Folder</td><td style=\"padding:10px 14px;border:1px solid #d6dee6;word-break:break-word;overflow-wrap:break-word;\"><a href=\"{{MatrixFolderPath}}\" style=\"color:#2e7d9a;text-decoration:none;\">{{MatrixFolderDisplayName}}</a></td></tr><tr><td style=\"background-color:#fafbfc;color:#6b7280;padding:10px 14px;border:1px solid #d6dee6;\">Responsible</td><td style=\"padding:10px 14px;border:1px solid #d6dee6;color:#333333;word-break:break-word;overflow-wrap:break-word;\">{{MatrixResponsible}}</td></tr></table></td></tr><tr><td style=\"padding:18px 28px 4px 28px;\"><div style=\"color:#1f3a5f;font-weight:bold;font-size:14px;padding-bottom:10px;\">Folder access summary</div><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:100%;table-layout:fixed;border-collapse:separate;border-spacing:0;\"><tr><td width=\"50%\" valign=\"top\" style=\"width:50%;padding-right:8px;\"><div style=\"background-color:#f0f6f8;border:1px solid #d6dee6;padding:14px 16px;\"><div style=\"color:#2e7d9a;font-size:26px;font-weight:bold;line-height:28px;word-break:break-word;overflow-wrap:break-word;\">{{UniqueUserCount}}</div><div style=\"color:#6b7280;font-size:12px;padding-top:2px;\">Unique users</div></div></td><td width=\"50%\" valign=\"top\" style=\"width:50%;padding-left:8px;\"><div style=\"background-color:#f0f6f8;border:1px solid #d6dee6;padding:14px 16px;\"><div style=\"color:#2e7d9a;font-size:26px;font-weight:bold;line-height:28px;word-break:break-word;overflow-wrap:break-word;\">{{UniqueGroupCount}}</div><div style=\"color:#6b7280;font-size:12px;padding-top:2px;\">Unique groups</div></div></td></tr></table><p style=\"margin:12px 0 0 0;color:#9aa3ad;font-size:11px;font-style:italic;\">* Check the attachment for the full access details.</p></td></tr><tr><td style=\"padding:18px 28px 22px 28px;border-top:1px solid #eef0f2;\"><div style=\"color:#6b7280;font-size:12px;font-weight:bold;padding-bottom:6px;\">More information</div><div style=\"font-size:12px;line-height:20px;\"><a href=\"https://confluence.heidelbergcement.com/display/BNL/BNL+Help%3A+Access+Matrix+and+Roles%2C+an+introduction\" target=\"_blank\" style=\"color:#2e7d9a;text-decoration:none;\">Access matrix and roles: an introduction</a><br><a href=\"https://confluence.heidelbergcement.com/display/BNL/BNL+Help%3A+Matrix+Managers%3A+audit+reports+management\" target=\"_blank\" style=\"color:#2e7d9a;text-decoration:none;\">Matrix managers: audit reports management</a></div></td></tr></table></td></tr></table>",
      "Smtp": {
        "ServerName": "SERVER1.EXAMPLE.COM",
        "Port": 25,
        "ConnectionType": "None",
        "UserName": "",
        "Password": ""
      },
      "AssemblyPath": {
        "MailKit": "C:\\Program Files\\PackageManagement\\NuGet\\Packages\\MailKit.4.13.0\\lib\\net8.0\\MailKit.dll",
        "MimeKit": "C:\\Program Files\\PackageManagement\\NuGet\\Packages\\MimeKit.4.13.0\\lib\\net8.0\\MimeKit.dll"
      }
    },
    "SaveLogFiles": {
      "Detailed": false,
      "Where": {
        "Folder": "C:\\Log\\File or folder\\Permission matrix audit report"
      },
      "DeleteLogsAfterDays": 30
    },
    "SaveInEventLog": {
      "Save": true,
      "LogName": "Scripts"
    }
  },
  "?": {
    "AuditReport": {
      "RequestTicketURL": "(Mandatory) URL of the IT self-service request form, used for the {{RequestTicketURL}} token in 'Settings.SendMail.Body'. The presence of this 'AuditReport' section is also what tells the import stage to read the 'FormData' worksheet (which holds 'MatrixResponsible').",
      "ScriptAdmin": "(Mandatory) Array of e-mail addresses that are BCC'd on every audit mail and that receive the summary of matrices skipped for fatal errors, as well as initialization-failure notifications."
    },
    "Matrix": {
      "Archive": "(Mandatory) Keep 'false' for the audit report: the audit only reads the matrices and must not move them to the Archive folder.",
      "AdGroupPlaceHolders": "(Optional) SamAccountNames excluded from group membership checks (placeholder accounts). Same meaning as 'ExcludedSamAccountName' in the old standalone audit script."
    },
    "Settings": {
      "SendMail": {
        "To": "(Optional) Leave empty: the audit resolves recipients per matrix from the 'MatrixResponsible' field. A value here can be used as a test override.",
        "Bcc": "(Optional) Addresses that receive a blind copy of every audit mail (e.g. the access administrators).",
        "Subject": "(Optional) Subject template. Supports the {{Token}} placeholders listed under 'Body'.",
        "Body": "(Mandatory) HTML body template. Supported tokens: {{MatrixFileName}}, {{MatrixFilePath}}, {{MatrixCategoryName}}, {{MatrixSubCategoryName}}, {{MatrixFolderPath}}, {{MatrixFolderDisplayName}}, {{MatrixResponsible}}, {{UniqueUserCount}}, {{UniqueGroupCount}}, {{RequestTicketURL}}."
      }
    },
    "Export": "(Unused) The audit report does not write export files; these are kept null. The 'ServiceNow' section is unused as well."
  }
}